rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isApprovedUser() {
      return signedIn()
        && userDoc().data.approved == true;
    }

    function isAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && userDoc().data.approved == true
        && userDoc().data.role == 'admin';
    }

    function isValidImage() {
      return request.resource.size < 500 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    /** Logo / ไฟล์บริษัท — อ่านได้โดยไม่ต้อง login (ใช้บนเอกสารพิมพ์) */
    match /Company/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** รูปแนบสัญญารับจ้าง — ต่อคัน */
    match /hiring-contracts/{contractId}/vehicles/{lineIndex}/{fileName} {
      allow read: if isApprovedUser();
      allow create, update: if isApprovedUser() && isValidImage();
      allow delete: if isApprovedUser();
    }

    /** Admin เข้าถึงทุก path */
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
