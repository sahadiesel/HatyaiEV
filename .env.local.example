# =============================================================================
# คัดลอกไฟล์นี้เป็น `.env.local` (อยู่โฟลเดอร์เดียวกับ package.json)
# ไฟล์ `.env.local` ไม่ควร commit ขึ้น git
#
# HYEV ใช้ Firestore อย่างเดียว — local กับ production ใช้โปรเจกต์เดียวกัน (แบบ saha_new)
# ต้องใส่ NEXT_PUBLIC_FIREBASE_* ครบชุดด้านล่าง
#
# Server actions (บันทึกข้อมูล) ต้องมี Firebase Admin บน local:
#   - วาง serviceAccountKey.json ในโฟลเดอร์โปรเจกต์ หรือ
#   - ตั้ง FIREBASE_SERVICE_ACCOUNT_PATH ด้านล่าง หรือ
#   - รัน gcloud auth application-default login
# =============================================================================

NEXT_PUBLIC_FIREBASE_API_KEY=ใส่ค่า_apiKey_จาก_Console
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=auto-repair-management.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=auto-repair-management
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=auto-repair-management.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=ใส่เลข_messagingSenderId
NEXT_PUBLIC_FIREBASE_APP_ID=ใส่ค่า_appId
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=ใส่ถ้ามีใน_config_ไม่มีก็ลบบรรทัดนี้

# Service Account สำหรับ server actions บน local
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# (ไม่บังคับ) URL logo จาก Firebase Storage
# NEXT_PUBLIC_COMPANY_LOGO_URL=https://firebasestorage.googleapis.com/v0/b/auto-repair-management.firebasestorage.app/o/Company%2FLogo_HYEV.png?alt=media&token=25341e05-002c-4e94-adb4-a6858377e417
