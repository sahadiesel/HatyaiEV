# =============================================================================
# คัดลอกไฟล์นี้เป็น `.env.local` (อยู่โฟลเดอร์เดียวกับ package.json)
# ไฟล์ `.env.local` ไม่ควร commit ขึ้น git
#
# Prisma (SQLite) — จำเป็นต่อ server action; path สัมพันธ์กับโฟลเดอร์ prisma/
DATABASE_URL="file:./dev.db"
#
# ค่าที่ต้องใส่มาจาก Firebase Console ไม่ใช่จากเอกสารใน Firestore
# ไปที่: ไอคอนเฟือง ⚙️ > Project settings > เลื่อนลง "Your apps" > เลือกแอปเว็บ
# > "SDK setup and configuration" > จะเห็น const firebaseConfig = { ... }
#
# แมปค่าแบบนี้:
#   apiKey                 → NEXT_PUBLIC_FIREBASE_API_KEY
#   authDomain             → NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
#   projectId              → NEXT_PUBLIC_FIREBASE_PROJECT_ID
#   storageBucket          → NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
#   messagingSenderId      → NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
#   appId                  → NEXT_PUBLIC_FIREBASE_APP_ID
#   measurementId (ถ้ามี) → NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID
#
# โปรเจกต์ของคุณชื่อ "Auto Repair Management" → projectId มักเป็น:
#   auto-repair-management
# authDomain มักเป็น:
#   auto-repair-management.firebaseapp.com
# storageBucket มักเป็นอย่างใดอย่างหนึ่ง:
#   auto-repair-management.appspot.com
#   หรือ auto-repair-management.firebasestorage.app
# =============================================================================

NEXT_PUBLIC_FIREBASE_API_KEY=ใส่ค่า_apiKey_จาก_Console
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=auto-repair-management.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=auto-repair-management
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=auto-repair-management.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=ใส่เลข_messagingSenderId
NEXT_PUBLIC_FIREBASE_APP_ID=ใส่ค่า_appId
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=ใส่ถ้ามีใน_config_ไม่มีก็ลบบรรทัดนี้
